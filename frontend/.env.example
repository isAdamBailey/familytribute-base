# Nuxt frontend environment (issue #19, Phase 2).
# Copy to .env for local dev. All values are read via runtimeConfig in
# nuxt.config.ts.

# Browser-facing Laravel API base (includes /api). Local dev default.
NUXT_PUBLIC_API_BASE=http://localhost:8000/api

# Backend origin (no /api) for the Sanctum CSRF-cookie + Fortify auth routes.
NUXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8000

# Optional: base the Nuxt SSR server uses to reach Laravel directly. Defaults
# to NUXT_PUBLIC_API_BASE when blank. Useful when SSR should hit an internal
# host (e.g. http://127.0.0.1:8000/api) instead of the public origin.
NUXT_API_BASE_SERVER=

# Production (two-subdomain topology — see issue #19 Phase 2 / Phase 6):
#   NUXT_PUBLIC_API_BASE=https://api.familytribute.example/api
#   NUXT_PUBLIC_BACKEND_ORIGIN=https://api.familytribute.example
